<script>
// --- Tab Switching ---
document.querySelectorAll('nav button').forEach(btn=>{
    btn.addEventListener('click',()=>{
        document.querySelectorAll('nav button').forEach(b=>b.classList.remove('active'));
        document.querySelectorAll('section').forEach(s=>s.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById(btn.dataset.tab).classList.add('active');
    });
});

// --- Demo Login/Register ---
let currentUser = null;
function register(){
    const u = document.getElementById('username').value;
    if(!u) return alert("Enter a username");
    currentUser = u;
    document.getElementById('loginMsg').innerText = "Registered as " + u;
}
function login(){
    const u = document.getElementById('username').value;
    if(!u) return alert("Enter a username");
    currentUser = u;
    document.getElementById('loginMsg').innerText = "Logged in as " + u;
}

// --- GPT AI Dungeon ---
async function runDungeon(){
    if(!currentUser){ alert("Login first"); return;}
    const title = document.getElementById('dungeonTitle').value || "Story";
    const promptText = document.getElementById('dungeonInput').value;
    const output = document.getElementById('dungeonOutput');

    // Call your GPT API here (demo uses reversed text)
    // Replace with fetch('/api/gpt', {method:'POST', body:JSON.stringify({prompt:promptText})})
    const aiResp = "🤖 " + promptText.split('').reverse().join('');

    output.innerText = aiResp;
    // Store in URL param for sharing
    const storyData = {title, prompt: promptText, aiResp};
    const encoded = encodeURIComponent(JSON.stringify(storyData));
    window.history.replaceState(null, "", "?story=" + encoded);
}

// Share Story
function shareDungeon(){
    const link = window.location.href;
    prompt("Share this story link:", link);
}

// Load story from URL
window.addEventListener('load', ()=>{
    const params = new URLSearchParams(window.location.search);
    if(params.has('story')){
        const data = JSON.parse(decodeURIComponent(params.get('story')));
        document.getElementById('dungeonTitle').value = data.title;
        document.getElementById('dungeonInput').value = data.prompt;
        document.getElementById('dungeonOutput').innerText = data.aiResp;
        document.querySelector('nav button[data-tab="dungeon"]').click();
    }
});

// --- Game Maker ---
function makeGame(){
    const code = document.getElementById('makerInput').value;
    const area = document.getElementById('gamePlayArea');
    area.innerHTML = `<canvas id="c" width="300" height="300"></canvas>`;
    const canvas = document.getElementById('c');
    const ctx = canvas.getContext('2d');
    try { eval(code); document.getElementById('makerOutput').innerText = "Game running!"; }
    catch(e){ document.getElementById('makerOutput').innerText = "Error: "+e; }
}

// Share Game
function shareGame(){
    const code = document.getElementById('makerInput').value;
    const encoded = encodeURIComponent(code);
    const link = window.location.origin + window.location.pathname + "?game=" + encoded;
    prompt("Share this game link:", link);
}

// Load game from URL
window.addEventListener('load', ()=>{
    const params = new URLSearchParams(window.location.search);
    if(params.has('game')){
        const code = decodeURIComponent(params.get('game'));
        document.getElementById('makerInput').value = code;
        makeGame();
        document.querySelector('nav button[data-tab="maker"]').click();
    }
});

// --- GPT AI Chat ---
async function sendChat(){
    if(!currentUser){ alert("Login first"); return;}
    const msg = document.getElementById('chatInput').value;
    const win = document.getElementById('chatWindow');
    win.innerHTML += `\nYou: ${msg}`;

    // Replace this with GPT API call
    const resp = "🤖 " + msg.split('').reverse().join('');
    win.innerHTML += `\nAI: ${resp}`;
    document.getElementById('chatInput').value="";
    win.scrollTop = win.scrollHeight;
}
</script>
