<button class="action" onclick="login()">Login</button>
<div id="loginMsg" class="output"></div>
</section>

<section id="dungeon">
<h2>AI Dungeon</h2>
<input id="dungeonTitle" placeholder="Story title">
<textarea id="dungeonInput" placeholder="Your prompt..."></textarea>
<button class="action" onclick="runDungeon()">Generate Story</button>
<button class="action" onclick="shareDungeon()">Share Story</button>
<div id="dungeonOutput" class="output"></div>
</section>

